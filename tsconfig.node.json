{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./ts-out",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["vite.config.ts", "electron"]
}
